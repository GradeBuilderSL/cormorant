# Vitis HLS synthesis script for PoolingKernel — generated by CMake.
# Runs C synthesis and exports the result as a Vivado IP catalog archive.
#
# Variables substituted by CMake configure_file (@ONLY):
#   POOL_HLS_PROJECT_NAME   — HLS project directory name
#   POOL_BOARD_OPTION       — set_part command (includes -board if present)
#   POOL_SRC_SYNTHESIS      — kernel source file path
#   POOL_SYNTHESIS_FLAGS    — -O3 plus -I paths for include directories
#   POOL_TARGET_CLOCK_TCL   — target clock frequency in MHz
#   POOL_IP_OUTPUT_DIR      — output directory for the exported IP catalog

open_project @POOL_HLS_PROJECT_NAME@
open_solution solution1 -flow_target vivado

@POOL_BOARD_OPTION@

add_files -cflags "@POOL_SYNTHESIS_FLAGS@" "@POOL_SRC_SYNTHESIS@"
set_top PoolingKernel

create_clock -period @POOL_TARGET_CLOCK_TCL@MHz -name default

# 64-bit AXI addresses for systems with >4 GB address space (e.g. KV260 PS DDR).
config_interface -m_axi_addr64
# Widen m_axi data bus to 32-bit to match the 32-bit AXI Interconnect crossbar
# in the block design (avoids needing a data-width converter on each gmem port).
config_interface -m_axi_max_widen_bitwidth 32
config_rtl -reset_level low

csynth_design
export_design -format ip_catalog -output @POOL_IP_OUTPUT_DIR@

exit
