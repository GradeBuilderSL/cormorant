# Vitis HLS synthesis script for MatmulKernel — generated by CMake.
# Runs C synthesis and exports the result as a Vivado IP catalog archive.
#
# Variables substituted by CMake configure_file (@ONLY):
#   MM_HLS_PROJECT_NAME      — HLS project directory name
#   MM_BOARD_OPTION          — set_part command (includes -board if present)
#   MM_SRC_SYNTHESIS         — space-separated kernel source file paths
#   MM_SYNTHESIS_FLAGS       — -O3 plus -I paths for include directories
#   MM_TARGET_CLOCK_TCL      — target clock frequency in MHz
#   MM_IP_OUTPUT_DIR         — output directory for the exported IP catalog

open_project @MM_HLS_PROJECT_NAME@
open_solution solution1 -flow_target vivado

@MM_BOARD_OPTION@

add_files -cflags "@MM_SYNTHESIS_FLAGS@" "@MM_SRC_SYNTHESIS@"
set_top MatmulKernel

create_clock -period @MM_TARGET_CLOCK_TCL@MHz -name default

# 64-bit AXI addresses for systems with >4 GB address space (e.g. KV260 PS DDR).
config_interface -m_axi_addr64
# Widen m_axi data bus to 32-bit so the generated IP ports match the 32-bit
# AXI Interconnect crossbar in the block design (avoids needing a data-width
# converter between each gmem port and the interconnect slave port).
config_interface -m_axi_max_widen_bitwidth 32
config_rtl -reset_level low

csynth_design
export_design -format ip_catalog -output @MM_IP_OUTPUT_DIR@

exit
