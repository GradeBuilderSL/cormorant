# Vitis HLS synthesis script for ConvKernel — generated by CMake.
# Runs C synthesis and exports the result as a Vivado IP catalog archive.
#
# Variables substituted by CMake configure_file (@ONLY):
#   CONV_HLS_PROJECT_NAME   — HLS project directory name
#   CONV_BOARD_OPTION       — set_part command (includes -board if present)
#   CONV_SRC_SYNTHESIS      — kernel source file path
#   CONV_SYNTHESIS_FLAGS    — -O3 plus -I paths for include directories
#   CONV_TARGET_CLOCK_TCL   — target clock frequency in MHz
#   CONV_IP_OUTPUT_DIR      — output directory for the exported IP catalog

open_project @CONV_HLS_PROJECT_NAME@
open_solution solution1 -flow_target vivado

@CONV_BOARD_OPTION@

add_files -cflags "@CONV_SYNTHESIS_FLAGS@" "@CONV_SRC_SYNTHESIS@"
set_top ConvKernel

create_clock -period @CONV_TARGET_CLOCK_TCL@MHz -name default

# 64-bit AXI addresses for systems with >4 GB address space (e.g. KV260 PS DDR).
config_interface -m_axi_addr64
# Widen m_axi data bus to 32-bit to match the 32-bit AXI Interconnect crossbar
# in the block design (avoids needing a data-width converter on each gmem port).
config_interface -m_axi_max_widen_bitwidth 32
config_rtl -reset_level low

csynth_design
export_design -format ip_catalog -output @CONV_IP_OUTPUT_DIR@

exit
