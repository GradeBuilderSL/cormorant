{
  "_comment": "Copy this file to perf_config.json and fill in your KV260 details.",

  "ssh": {
    "host": "kv260.local",
    "user": "root",
    "port": 22,

    "key_file": "~/.ssh/id_rsa",
    "_key_file_note": "Path to SSH private key. Set to null to use password auth instead.",

    "password": null,
    "_password_note": "SSH password. Leave null when using key-based auth.",

    "connect_timeout": 15
  },

  "remote": {
    "work_dir": "/tmp/kernel_perf",
    "_work_dir_note": "Temporary build directory on the remote machine. Created automatically. Cleaned up after the run unless --no-cleanup is set.",

    "uio_devices": {
      "VectorOPKernel": "VectorOPKernel_0",
      "MatmulKernel":   "MatmulKernel_0",
      "ConvKernel":     "ConvKernel_0",
      "PoolingKernel":  "PoolingKernel_0"
    },
    "_uio_devices_note": "Per-kernel UIO sysfs names — the strings in /sys/class/uio/uio*/name, NOT /dev/uioN paths. Verify after loading the DTBO: cat /sys/class/uio/uio*/name. Only list kernels present in the active bitstream.",

    "driver_dir": null,
    "driver_dirs": {},
    "_driver_dirs_note": "Per-kernel paths ON THE BOARD to copy driver sources from. Takes precedence over local.driver_dirs only when local.driver_dirs is empty.",

    "cmake_args": []
  },

  "local": {
    "driver_dir": null,
    "driver_dirs": {
      "VectorOPKernel": "/path/to/axi_demo/build/kernels/vectorop/kv260/vadd_kv260/solution1/impl/ip/drivers/VectorOPKernel_v1_0/src",
      "MatmulKernel":   "/path/to/axi_demo/build/kernels/matmul/kv260/matmul_kv260/solution1/impl/ip/drivers/MatmulKernel_v1_0/src",
      "ConvKernel":     "/path/to/axi_demo/build/kernels/conv/kv260/conv_kv260/solution1/impl/ip/drivers/ConvKernel_v1_0/src",
      "PoolingKernel":  "/path/to/axi_demo/build/kernels/pool/kv260/pool_kv260/solution1/impl/ip/drivers/PoolingKernel_v1_0/src"
    },
    "_driver_dirs_note": "Per-kernel local HLS driver source paths. Merged and bundled before upload. Standard Vitis HLS output location shown; adjust to your build directory."
  },

  "build": {
    "jobs": 4,
    "timeout": 300,
    "_timeout_note": "Combined cmake + make timeout in seconds. 300s is recommended for the four-kernel benchmark project."
  },

  "run": {
    "timeout": 120,
    "use_sudo": true,
    "_use_sudo_note": "Run each benchmark binary with 'sudo -n'. Requires passwordless sudo on the board."
  },

  "cleanup": true,
  "_cleanup_note": "Remove remote work_dir after all benchmarks finish. Set false (or use --no-cleanup) to keep the build for manual invocation.",

  "benchmarks": {
    "_note": "Kernels without a 'cases' array are skipped. Set 'enabled' to false to skip a kernel without removing its cases.",

    "VectorOPKernel": {
      "enabled": true,
      "warmup": 10,
      "cases": [
        {"label": "ADD-1K",           "op": 0, "size": 1024,   "outer": 1, "a_inc": 0,     "b_inc": 0, "iters": 200},
        {"label": "ADD-4K",           "op": 0, "size": 4096,   "outer": 1, "a_inc": 0,     "b_inc": 0, "iters": 200},
        {"label": "ADD-16K",          "op": 0, "size": 16384,  "outer": 1, "a_inc": 0,     "b_inc": 0, "iters": 200},
        {"label": "ADD-64K",          "op": 0, "size": 65536,  "outer": 1, "a_inc": 0,     "b_inc": 0, "iters": 100},
        {"label": "ADD-256K",         "op": 0, "size": 262144, "outer": 1, "a_inc": 0,     "b_inc": 0, "iters": 50},
        {"label": "MUL-16K",          "op": 2, "size": 16384,  "outer": 1, "a_inc": 0,     "b_inc": 0, "iters": 200},
        {"label": "MUL-64K",          "op": 2, "size": 65536,  "outer": 1, "a_inc": 0,     "b_inc": 0, "iters": 100},
        {"label": "DIV-4K",           "op": 3, "size": 4096,   "outer": 1, "a_inc": 0,     "b_inc": 0, "iters": 50},
        {"label": "RELU-16K",         "op": 4, "size": 16384,  "outer": 1, "a_inc": 0,     "b_inc": 0, "iters": 200},
        {"label": "RELU-64K",         "op": 4, "size": 65536,  "outer": 1, "a_inc": 0,     "b_inc": 0, "iters": 100},
        {"label": "RELU6-16K",        "op": 5, "size": 16384,  "outer": 1, "a_inc": 0,     "b_inc": 0, "iters": 200},
        {"label": "ADD-bcast-8x16K",  "op": 0, "size": 16384,  "outer": 8, "a_inc": 16384, "b_inc": 0, "iters": 100},
        {"label": "MUL-bcast-8x16K",  "op": 2, "size": 16384,  "outer": 8, "a_inc": 16384, "b_inc": 0, "iters": 100},
        {"label": "RELU-bcast-8x16K", "op": 4, "size": 16384,  "outer": 8, "a_inc": 16384, "b_inc": 0, "iters": 100}
      ]
    },

    "MatmulKernel": {
      "enabled": true,
      "warmup": 10,
      "cases": [
        {"label": "8x8x8",           "n": 8,   "k": 8,   "m": 8,   "batch": 1, "a_stride": 0,    "b_stride": 0,    "iters": 500},
        {"label": "16x16x16",        "n": 16,  "k": 16,  "m": 16,  "batch": 1, "a_stride": 0,    "b_stride": 0,    "iters": 500},
        {"label": "32x32x32",        "n": 32,  "k": 32,  "m": 32,  "batch": 1, "a_stride": 0,    "b_stride": 0,    "iters": 200},
        {"label": "64x64x64",        "n": 64,  "k": 64,  "m": 64,  "batch": 1, "a_stride": 0,    "b_stride": 0,    "iters": 100},
        {"label": "128x128x128",     "n": 128, "k": 128, "m": 128, "batch": 1, "a_stride": 0,    "b_stride": 0,    "iters": 50},
        {"label": "256x256x256",     "n": 256, "k": 256, "m": 256, "batch": 1, "a_stride": 0,    "b_stride": 0,    "iters": 20},
        {"label": "FC-1x256x256",    "n": 1,   "k": 256, "m": 256, "batch": 1, "a_stride": 0,    "b_stride": 0,    "iters": 500},
        {"label": "FC-4x256x256",    "n": 4,   "k": 256, "m": 256, "batch": 1, "a_stride": 0,    "b_stride": 0,    "iters": 200},
        {"label": "batch4-64x64x64", "n": 64,  "k": 64,  "m": 64,  "batch": 4, "a_stride": 4096, "b_stride": 4096, "iters": 50},
        {"label": "batch4-A-bcast",  "n": 64,  "k": 64,  "m": 64,  "batch": 4, "a_stride": 0,    "b_stride": 4096, "iters": 50}
      ]
    },

    "ConvKernel": {
      "enabled": true,
      "warmup": 10,
      "cases": [
        {"label": "3x3-1ch-28x28-32out", "batch": 1, "in_ch": 1,   "in_h": 28, "in_w": 28, "out_ch": 32,  "kh": 3, "kw": 3, "stride_h": 1, "stride_w": 1, "dilation_h": 1, "dilation_w": 1, "pad_top": 1, "pad_left": 1, "has_bias": 0, "is_dw": 0, "iters": 200},
        {"label": "3x3-64ch-56x56",      "batch": 1, "in_ch": 64,  "in_h": 56, "in_w": 56, "out_ch": 64,  "kh": 3, "kw": 3, "stride_h": 1, "stride_w": 1, "dilation_h": 1, "dilation_w": 1, "pad_top": 1, "pad_left": 1, "has_bias": 0, "is_dw": 0, "iters": 50},
        {"label": "3x3-64ch-56x56-s2",   "batch": 1, "in_ch": 64,  "in_h": 56, "in_w": 56, "out_ch": 64,  "kh": 3, "kw": 3, "stride_h": 2, "stride_w": 2, "dilation_h": 1, "dilation_w": 1, "pad_top": 1, "pad_left": 1, "has_bias": 0, "is_dw": 0, "iters": 50},
        {"label": "3x3-64ch-28x28",      "batch": 1, "in_ch": 64,  "in_h": 28, "in_w": 28, "out_ch": 64,  "kh": 3, "kw": 3, "stride_h": 1, "stride_w": 1, "dilation_h": 1, "dilation_w": 1, "pad_top": 1, "pad_left": 1, "has_bias": 0, "is_dw": 0, "iters": 100},
        {"label": "1x1-64to128-56x56",   "batch": 1, "in_ch": 64,  "in_h": 56, "in_w": 56, "out_ch": 128, "kh": 1, "kw": 1, "stride_h": 1, "stride_w": 1, "dilation_h": 1, "dilation_w": 1, "pad_top": 0, "pad_left": 0, "has_bias": 0, "is_dw": 0, "iters": 50},
        {"label": "1x1-128to256-28x28",  "batch": 1, "in_ch": 128, "in_h": 28, "in_w": 28, "out_ch": 256, "kh": 1, "kw": 1, "stride_h": 1, "stride_w": 1, "dilation_h": 1, "dilation_w": 1, "pad_top": 0, "pad_left": 0, "has_bias": 0, "is_dw": 0, "iters": 50},
        {"label": "5x5-16ch-28x28",      "batch": 1, "in_ch": 16,  "in_h": 28, "in_w": 28, "out_ch": 16,  "kh": 5, "kw": 5, "stride_h": 1, "stride_w": 1, "dilation_h": 1, "dilation_w": 1, "pad_top": 2, "pad_left": 2, "has_bias": 0, "is_dw": 0, "iters": 100},
        {"label": "dw-3x3-32ch-28x28",   "batch": 1, "in_ch": 32,  "in_h": 28, "in_w": 28, "out_ch": 32,  "kh": 3, "kw": 3, "stride_h": 1, "stride_w": 1, "dilation_h": 1, "dilation_w": 1, "pad_top": 1, "pad_left": 1, "has_bias": 0, "is_dw": 1, "iters": 200},
        {"label": "dw-3x3-64ch-56x56",   "batch": 1, "in_ch": 64,  "in_h": 56, "in_w": 56, "out_ch": 64,  "kh": 3, "kw": 3, "stride_h": 1, "stride_w": 1, "dilation_h": 1, "dilation_w": 1, "pad_top": 1, "pad_left": 1, "has_bias": 0, "is_dw": 1, "iters": 50}
      ]
    },

    "PoolingKernel": {
      "enabled": true,
      "warmup": 10,
      "cases": [
        {"label": "MaxPool-2x2-56x56",   "batch": 1, "channels": 64, "in_h": 56, "in_w": 56, "pool_h": 2,  "pool_w": 2,  "stride_h": 2, "stride_w": 2, "pad_top": 0, "pad_left": 0, "dil_h": 1, "dil_w": 1, "pool_type": 0, "lp_order": 1, "count_include_pad": 0, "iters": 200},
        {"label": "MaxPool-2x2-28x28",   "batch": 1, "channels": 64, "in_h": 28, "in_w": 28, "pool_h": 2,  "pool_w": 2,  "stride_h": 2, "stride_w": 2, "pad_top": 0, "pad_left": 0, "dil_h": 1, "dil_w": 1, "pool_type": 0, "lp_order": 1, "count_include_pad": 0, "iters": 200},
        {"label": "MaxPool-3x3-56x56",   "batch": 1, "channels": 64, "in_h": 56, "in_w": 56, "pool_h": 3,  "pool_w": 3,  "stride_h": 2, "stride_w": 2, "pad_top": 1, "pad_left": 1, "dil_h": 1, "dil_w": 1, "pool_type": 0, "lp_order": 1, "count_include_pad": 0, "iters": 100},
        {"label": "MaxPool-3x3-14x14",   "batch": 1, "channels": 64, "in_h": 14, "in_w": 14, "pool_h": 3,  "pool_w": 3,  "stride_h": 2, "stride_w": 2, "pad_top": 1, "pad_left": 1, "dil_h": 1, "dil_w": 1, "pool_type": 0, "lp_order": 1, "count_include_pad": 0, "iters": 200},
        {"label": "AvgPool-2x2-56x56",   "batch": 1, "channels": 64, "in_h": 56, "in_w": 56, "pool_h": 2,  "pool_w": 2,  "stride_h": 2, "stride_w": 2, "pad_top": 0, "pad_left": 0, "dil_h": 1, "dil_w": 1, "pool_type": 1, "lp_order": 1, "count_include_pad": 0, "iters": 200},
        {"label": "AvgPool-3x3-28x28",   "batch": 1, "channels": 64, "in_h": 28, "in_w": 28, "pool_h": 3,  "pool_w": 3,  "stride_h": 2, "stride_w": 2, "pad_top": 1, "pad_left": 1, "dil_h": 1, "dil_w": 1, "pool_type": 1, "lp_order": 1, "count_include_pad": 0, "iters": 200},
        {"label": "GlobalMaxPool-14x14", "batch": 1, "channels": 64, "in_h": 14, "in_w": 14, "pool_h": 14, "pool_w": 14, "stride_h": 1, "stride_w": 1, "pad_top": 0, "pad_left": 0, "dil_h": 1, "dil_w": 1, "pool_type": 0, "lp_order": 1, "count_include_pad": 0, "iters": 200},
        {"label": "GlobalAvgPool-7x7",   "batch": 1, "channels": 64, "in_h": 7,  "in_w": 7,  "pool_h": 7,  "pool_w": 7,  "stride_h": 1, "stride_w": 1, "pad_top": 0, "pad_left": 0, "dil_h": 1, "dil_w": 1, "pool_type": 1, "lp_order": 1, "count_include_pad": 0, "iters": 200}
      ]
    }
  }
}
