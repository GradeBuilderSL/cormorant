{
  "_comment": "Bitstream upload config for KV260. Paths are relative to this file.",

  "ssh": {
    "host": "kv260.local",
    "_host_note": "IP address or hostname of the KV260 board.",

    "user": "root",
    "port": 22,

    "key_file": "~/.ssh/id_rsa",
    "_key_file_note": "Path to SSH private key. Set to null to use password auth.",

    "password": null,
    "connect_timeout": 15
  },

  "bitstream": {
    "bit": "/path/to/hw/cormorant_hw_128/cormorant_hw_128.runs/impl_1/design_cormorant_wrapper.bit",
    "_bit_note": "Vivado .bit output. Build with: make build_hw_kv260",

    "hwh": "/path/to/hw/cormorant_hw_128/cormorant_hw_128.gen/sources_1/bd/design_cormorant/hw_handoff/design_cormorant.hwh",
    "_hwh_note": "Hardware handoff file generated by Vivado synthesis. Can be omitted when design_cormorant_wrapper.hwh sits alongside the .bit.",

    "dtbo": "/path/to/dts/kv260/cormorant.dtbo",
    "_dtbo_note": "Compiled device tree overlay. Build with: dtc -I dts -O dtb -o pl.dtbo pl.dts",

    "overlay_name": null,
    "_overlay_name_note": "Configfs dir name and /lib/firmware/<name>.bin. Defaults to the .dtbo file stem.",

    "xclbinutil": "xclbinutil",
    "_xclbinutil_note": "xclbinutil command or absolute path. Must be available (source Vitis settings64.sh or set full path)."
  }
}
